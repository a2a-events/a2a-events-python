{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://a2a-events.github.io/a2a-events/schemas/event.schema.json",
  "description": "A CloudEvents 1.0 event with the A2A Events extension attributes.\n\nThe A2A Events metadata travels as *flat scalar extension context\nattributes* (``a2atopic``, ``a2acursor``, ...), because the CloudEvents\ntype system has no map/object type: extension attributes MUST use the\nscalar type system and lowercase-alphanumeric names (CloudEvents 1.0\n\"Extension Context Attributes\" + \"Type System\"; names SHOULD be at most\n20 characters). A nested ``a2aevents`` object would not be a conformant\nextension attribute.",
  "properties": {
    "specversion": {
      "const": "1.0",
      "default": "1.0",
      "title": "Specversion",
      "type": "string"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "source": {
      "title": "Source",
      "type": "string"
    },
    "type": {
      "title": "Type",
      "type": "string"
    },
    "subject": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Subject"
    },
    "time": {
      "format": "date-time",
      "title": "Time",
      "type": "string"
    },
    "datacontenttype": {
      "default": "application/json",
      "title": "Datacontenttype",
      "type": "string"
    },
    "data": {
      "additionalProperties": true,
      "title": "Data",
      "type": "object"
    },
    "a2aextension": {
      "default": "https://a2a-events.github.io/a2a-events/extensions/events/v1",
      "title": "A2Aextension",
      "type": "string"
    },
    "a2apublisher": {
      "title": "A2Apublisher",
      "type": "string"
    },
    "a2atopic": {
      "title": "A2Atopic",
      "type": "string"
    },
    "a2acursor": {
      "title": "A2Acursor",
      "type": "string"
    },
    "a2aschemaurl": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "A2Aschemaurl"
    },
    "a2asubscription": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "A2Asubscription"
    },
    "a2adeliveryattempt": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "A2Adeliveryattempt"
    },
    "a2atraceid": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "A2Atraceid"
    }
  },
  "required": [
    "id",
    "source",
    "type",
    "time",
    "data",
    "a2apublisher",
    "a2atopic",
    "a2acursor"
  ],
  "title": "CloudEvent",
  "type": "object"
}
